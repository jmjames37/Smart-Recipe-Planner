# Copy this file to .env and fill in your values.

# The app calls a serverless proxy (api/messages.ts) that holds the Anthropic
# key SERVER-SIDE. The client never sees the key.

# --- Server (Vercel project env var, NOT prefixed EXPO_PUBLIC) ---
# Set in the Vercel dashboard or with: vercel env add ANTHROPIC_API_KEY
# Get a key at https://console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-...

# --- Mobile / local dev (client) ---
# Absolute URL of the deployed proxy, used by the native app (and local web dev).
# On the deployed web build this can be left blank (same-origin /api/messages).
EXPO_PUBLIC_PROXY_URL=https://your-app.vercel.app
